# SAMI PostgreSQL (read-write)
DATABASE_URL=postgresql://user:password@localhost:5432/sami

# SAP staging PostgreSQL (read-only; si falla el ping al arrancar, SAP_DB queda null)
SAP_DATABASE_URL=postgresql://user:password@localhost:5432/sap_staging

# Redis (sesiones)
REDIS_URL=redis://localhost:6379

PORT=3000
NODE_ENV=development

# Sesión (mínimo 32 caracteres)
SESSION_SECRET=change-me-use-at-least-32-chars-long-secret
SESSION_TTL=86400000
# Logs de sesión en consola: ok / fail (redis vs postgres). Por defecto ON en dev, OFF en production salvo que pongas true.
# LOG_SESSION_EVENTS=true

LDAP_URL=ldap://localhost:389
LDAP_BASE_DN=dc=example,dc=com
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=secret
# Base OU donde buscar usuarios AD (default: LDAP_BASE_DN)
# LDAP_SEARCH_BASE=OU=Users,DC=aris,DC=com,DC=pe
# Atributo AD donde guardáis pernr / código SAP (mapa: postalCode)
# LDAP_POSTALCODE_ATTR=postalCode
# Filtro personalizado; usar {sapCode} como placeholder (= pernr)
# LDAP_AUTH_FILTER=(&(objectClass=user)(objectCategory=person)(postalCode={sapCode}))
# Login por AD según correo_corp en SAP (default true). false = solo usuarios locales / registro.
# LDAP_AD_AUTH_ENABLED=false
# Estrategia AD: corporate_mail (cuenta por correo_corp), sap_code (postalCode=pernr), o ambos en orden.
# LDAP_AD_AUTH_STRATEGY=corporate_mail_then_sap_code

EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Cifrado de secretos guardados por módulo (SMTP en Ajustes). Obligatoria para Guardar en Ajustes → Correo.
# Cualquier cadena larga y secreta; internamente se usa SHA-256 para derivar la clave AES-256-GCM.
SETTINGS_ENCRYPTION_KEY=change-me-long-random-string-at-least-32-chars


# Throttler: ttl en ms (60000 = 1 min), limit = reqs por ventana
THROTTLER_TTL=60000
THROTTLER_LIMIT=100
